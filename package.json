{
  "name": "pebble-agent-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "pebble-agent-cli": "apps/agent-cli/dist-bundle/pebble-agent-cli.cjs"
  },
  "files": [
    "README.md",
    "apps/agent-cli/dist-bundle/pebble-agent-cli.cjs",
    "apps/agent-cli/package.json",
    "pnpm-workspace.yaml"
  ],
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "prepare": "pnpm --filter @pebble/agent-cli build",
    "test": "pnpm -r test",
    "dev:gateway": "pnpm --filter @pebble/gateway dev",
    "dev:cli": "pnpm --filter @pebble/agent-cli dev",
    "lint": "tsc -b --pretty false"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "node-gyp": "^12.3.0",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
